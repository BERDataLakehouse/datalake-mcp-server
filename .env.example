# Docker Compose environment variables for datalake-mcp-server
# Copy this file to .env and customize for your environment:
#   cp .env.example .env
#
# These variables control which KBase users the local dev stack simulates.
# The stack runs two Spark clusters:
#   - spark-connect-notebook: dedicated Spark Connect for CONNECT_USER
#   - standalone-spark-master: shared standalone cluster for STANDALONE_USER

# Spark Connect user (dedicated notebook/cluster)
CONNECT_USER=tgu2

# Standalone user (shared cluster, no dedicated notebook)
STANDALONE_USER=tgu3

# Comma-separated list of users exempt from MFA requirements
MFA_EXEMPT_USERS=${CONNECT_USER},${STANDALONE_USER},kbaselakehouseserviceaccount
